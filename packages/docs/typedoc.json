{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "../*/.docs/docs.json",
    "../infra-adapters/*/.docs/docs.json"
  ],
  "readme": "none",
  "plugin": ["typedoc-plugin-markdown", "./dist/typedoc/typedoc-uml/index.js"],
  "entryPointStrategy": "merge",
  "includeVersion": false,
  "outputs": [
    {
      "name": "html",
      "path": "./api/html"
    },
    {
      "name": "markdown",
      "path": "./api/md"
    }
  ]
}
