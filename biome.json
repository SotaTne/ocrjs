{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "ignoreUnknown": true,
    "includes": [
      "packages/**/*.{ts,tsx}",
      "packages/config/**/*.{json,ts}",
      "packages/**/package.json",
      "packages/**/typedoc.json",
      "apps/**/*.{ts,tsx}",
      "apps/**/package.json",
      ".vscode/*.json",
      "eslint.config.mts",
      "turbo.json",
      "biome.json"
    ]
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "suspicious": {
        "noExplicitAny": "warn",
        "noDoubleEquals": "error",
        "noConsole": "off",
        "noFallthroughSwitchClause": "error"
      },

      "correctness": {
        "noUnusedVariables": "warn"
      },

      "style": {
        "useImportType": "error",
        "useConst": "warn",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false,
            "conventions": [
              {
                "selector": { "kind": "interface" },
                "match": "I[A-Z].*",
                "formats": ["PascalCase"]
              },
              {
                "selector": { "kind": "class" },
                "formats": ["PascalCase"]
              },
              {
                "selector": { "kind": "classMethod" },
                "formats": ["camelCase"]
              },
              {
                "selector": { "kind": "classProperty" },
                "formats": ["camelCase"]
              },
              {
                "selector": { "kind": "variable" },
                "formats": ["camelCase", "CONSTANT_CASE", "snake_case"]
              },
              {
                "selector": { "kind": "function" },
                "formats": ["camelCase", "PascalCase", "snake_case"]
              }
            ]
          }
        },
        "useArrayLiterals": "error",
        "noExportedImports": "error",
        "noEnum": "error",
        "noMagicNumbers": "error",
        "noNamespace": "error",
        "noNonNullAssertion": "error",
        "noParameterProperties": "error",
        "noProcessEnv": "error",
        "noSubstr": "error",
        "noUnusedTemplateLiteral": "error",
        "noYodaExpression": "error",
        "useAtIndex": "error",
        "useConsistentArrayType": "error",
        "useConsistentBuiltinInstantiation": "error",
        "useDefaultSwitchClause": "error"
      }
    }
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },

  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx"],
      "linter": {
        "rules": {
          "style": {
            "noMagicNumbers": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/docs/src/typedoc/typedoc-uml-lite/**/*.{ts,tsx}"],
      "linter": {
        "rules": {
          "style": {
            "noMagicNumbers": "off",
            "useDefaultSwitchClause": "off",
            "noNonNullAssertion": "off",
            "useNamingConvention": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "noImplicitAnyLet": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedFunctionParameters": "off",
            "noUnusedPrivateClassMembers": "off"
          },
          "complexity": {
            "useOptionalChain": "off"
          }
        }
      }
    }
  ],

  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
