{
  "extends": "@ocrjs/config-tsconfig/node.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "dist",
    "types": ["node"]
  },
  "include": [
    "e2e/**/*.ts",
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/typedoc/typedoc-uml-lite/",
    "e2e/typedoc/fixtures/**"
  ],
}
